# Vercel KV — from Vercel dashboard → Storage → your KV store → .env.local
KV_REST_API_URL=
KV_REST_API_TOKEN=

# DeepL API — cron + `npm run fetch:snapshot` (MyMemory fallback if unset)
DEEPL_API_KEY=

# On-demand ISR revalidation — Vercel + GitHub Actions (see docs/SCHEDULER.md)
REVALIDATE_SECRET=
