# Vercel KV — from Vercel dashboard → Storage → your KV store → .env.local
KV_REST_API_URL=
KV_REST_API_TOKEN=

# DeepL API — cron + `npm run fetch:snapshot` (MyMemory fallback if unset)
DEEPL_API_KEY=

# Upstash QStash — scheduled fetch via /api/cron/fetch (see docs/SCHEDULER.md)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# On-demand ISR revalidation — legacy manual trigger (QStash route revalidates automatically)
REVALIDATE_SECRET=

# Optional: Discord failure notifications (Vercel + GitHub Actions manual backup)
DISCORD_WEBHOOK_URL=

# Public site URL — used for sitemap, Open Graph, Search Console (defaults to production)
NEXT_PUBLIC_SITE_URL=https://g7-dashboard.vercel.app

# Google Analytics 4 — measurement ID from GA admin (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console — HTML tag verification content value
GOOGLE_SITE_VERIFICATION=
